# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password
JWT_SECRET=replace_with_long_random_secret
PASSWORD_MIN_LENGTH=8
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_BOOTSTRAP_WINDOW_MS=3600000
RATE_LIMIT_BOOTSTRAP_MAX=5
RATE_LIMIT_REQUEST_RESET_WINDOW_MS=900000
RATE_LIMIT_REQUEST_RESET_MAX=5
RATE_LIMIT_RESET_WINDOW_MS=900000
RATE_LIMIT_RESET_MAX=10

# Database (use DATABASE_URL or PG* vars)
DATABASE_URL=postgres://app_user:app_password@127.0.0.1:5432/app_budget
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=app_user
PGPASSWORD=app_password
PGDATABASE=app_budget

# Frontend
VITE_API_URL=http://localhost:3001
